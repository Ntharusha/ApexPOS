key_pair_name = "apexpos-key"

# Your IP for SSH and K8s API access, e.g. "1.2.3.4/32"
admin_ip      = "YOUR_PUBLIC_IP/32"

# Email for CloudWatch alarm notifications
alert_email   = "you@example.com"

aws_region    = "ap-south-1"
environment   = "prod"

# Docker Hub registry namespace for image pulls
# Used by scripts/deploy-ec2.sh and image tags in k8s manifests.
# Example: "tharusha69"
docker_registry = "tharusha69"

# Backend image tag deployed by k8s manifests.
backend_image_tag = "latest"

